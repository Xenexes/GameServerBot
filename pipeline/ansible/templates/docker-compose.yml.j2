# Generated by Ansible pipeline — do not edit manually on server
# {{ "{{ }}" }} = Jinja2 resolved at render time (baked in)
# ${ } = Docker Compose reads from .env at runtime
services:
  game-server-bot:
    image: {{ docker_registry }}/game-server-bot:{{ app_version }}
    container_name: game-server-bot
    restart: unless-stopped
    mem_limit: 1024m
    environment:
      # Paketo buildpacks use JAVA_TOOL_OPTIONS, not JAVA_OPTS
      JAVA_TOOL_OPTIONS: "-XX:MaxRAMPercentage=75"
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}
      CRON_JOB_PASSWORD: ${CRON_JOB_PASSWORD}
      NITRADO_API_TOKEN: ${NITRADO_API_TOKEN}
      NITRADO_SERVER_ID: ${NITRADO_SERVER_ID}
      DISCORD_ENABLED: ${DISCORD_ENABLED:-false}
      DISCORD_BOT_TOKEN: ${DISCORD_BOT_TOKEN:-}
      DISCORD_GUILD_ID: ${DISCORD_GUILD_ID:-}
      DISCORD_NOTIFICATION_CHANNEL_ID: ${DISCORD_NOTIFICATION_CHANNEL_ID:-}
      DISCORD_ADMIN_ROLE_ID: ${DISCORD_ADMIN_ROLE_ID:-}
      DISCORD_ALLOWED_ROLE_ID: ${DISCORD_ALLOWED_ROLE_ID:-}
      DISCORD_WEBHOOK_URL: ${DISCORD_WEBHOOK_URL:-}
    volumes:
      - app_logs:/app/logs
    ports:
      - "8080:8080"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 90s
    networks:
      - game-server-bot-network

  cron:
    image: hectorm/supercronic
    container_name: game-server-bot-cron
    restart: unless-stopped
    environment:
      JOB_PASSWORD: ${CRON_JOB_PASSWORD}
    volumes:
      - ./crontab:/etc/crontab:ro
    depends_on:
      game-server-bot:
        condition: service_healthy
    networks:
      - game-server-bot-network

  hawser:
    image: ghcr.io/finsys/hawser:latest
    container_name: hawser
    restart: unless-stopped
    ports:
      - "2376:2376"
    environment:
      TOKEN: ${HAWSER_TOKEN}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - hawser_stacks:/data/stacks
    networks:
      - game-server-bot-network

networks:
  game-server-bot-network:
    driver: bridge
    name: game-server-bot-network

volumes:
  app_logs:
    name: game-server-bot-app-logs
  hawser_stacks:
    name: hawser-stacks
